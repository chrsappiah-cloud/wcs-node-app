<?xml version="1.0" encoding="UTF-8"?>
<svg width="200" height="200" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
  <defs>
    <linearGradient id="profileGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7c3aed;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background Circle -->
  <circle cx="100" cy="100" r="100" fill="url(#profileGradient)"/>

  <!-- Head -->
  <circle cx="100" cy="70" r="35" fill="#e2e8f0"/>

  <!-- Body -->
  <rect x="65" y="110" width="70" height="60" rx="10" fill="#e2e8f0"/>

  <!-- Accent Elements -->
  <circle cx="100" cy="100" r="95" fill="none" stroke="#06b6d4" stroke-width="2" opacity="0.5"/>

  <!-- Text -->
  <text x="100" y="180" font-size="16" font-weight="bold" fill="white" text-anchor="middle" font-family="Arial">
    Dr. Appiah-Thompson
  </text>
</svg>
