<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Healing Arts - World Class Scholars</title>
  <style>
    :root {
      --primary: #7c3aed;
      --secondary: #06b6d4;
      --accent: #10b981;
      --dark: #0f172a;
      --light: #f8fafc;
      --glow: 0 0 20px rgba(124, 58, 237, 0.5);
      --glow-green: 0 0 15px rgba(16, 185, 129, 0.4);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Segoe UI', 'Roboto', sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
      color: #e2e8f0;
      line-height: 1.6;
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* Canvas Background */
    .canvas-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      opacity: 0.3;
      pointer-events: none;
    }

    /* Hero Section */
    .hero {
      position: relative;
      z-index: 10;
      height: 100vh;
      display: grid;
      place-items: center;
      text-align: center;
      padding: 2rem;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(124, 58, 237, 0.1) 0%, transparent 70%);
      z-index: -1;
    }

    .hero-content {
      max-width: 900px;
      animation: fadeInUp 1.2s ease-out;
    }

    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 800;
      background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 50%, #10b981 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1.5rem;
      letter-spacing: -0.02em;
      text-shadow: var(--glow);
    }

    .hero-subtitle {
      font-size: clamp(1rem, 2vw, 1.25rem);
      color: #cbd5e1;
      margin-bottom: 3rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-image {
      max-width: 75%;
      height: auto;
      border-radius: 16px;
      box-shadow: 0 20px 60px rgba(124, 58, 237, 0.3);
      border: 1px solid rgba(124, 58, 237, 0.2);
      animation: float 4s ease-in-out infinite;
      transition: transform 0.3s ease;
    }

    .hero-image:hover {
      transform: scale(1.02) translateY(-10px);
      box-shadow: var(--glow);
    }

    /* Main Content Grid */
    .container {
      position: relative;
      z-index: 10;
      max-width: 1400px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }

    .content-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
      margin-bottom: 4rem;
    }

    /* Glass Card Styling */
    .card {
      background: rgba(30, 27, 75, 0.6);
      backdrop-filter: blur(20px);
      border-radius: 16px;
      border: 1px solid rgba(124, 58, 237, 0.2);
      padding: 2rem;
      transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(135deg, rgba(124, 58, 237, 0.1) 0%, transparent 50%);
      opacity: 0;
      transition: opacity 0.4s ease;
      z-index: -1;
    }

    .card:hover {
      transform: translateY(-12px) scale(1.02);
      box-shadow: var(--glow);
      border-color: rgba(124, 58, 237, 0.5);
    }

    .card:hover::before {
      opacity: 1;
    }

    /* Profile Card */
    .profile-card {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 2rem;
      align-items: flex-start;
    }

    .profile-img {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      object-fit: cover;
      box-shadow: 0 8px 32px rgba(124, 58, 237, 0.4);
      border: 2px solid rgba(124, 58, 237, 0.3);
      transition: transform 0.4s cubic-bezier(0.23, 1, 0.320, 1);
    }

    .profile-img:hover {
      transform: scale(1.08) rotate(5deg);
      box-shadow: var(--glow);
    }

    .profile-info h2 {
      color: var(--primary);
      font-size: 1.75rem;
      margin-bottom: 0.5rem;
    }

    .profile-title {
      color: var(--secondary);
      font-weight: 600;
      margin-bottom: 1rem;
      font-size: 1.1rem;
    }

    .profile-bio {
      color: #cbd5e1;
      margin-bottom: 1.5rem;
      line-height: 1.8;
    }

    .profile-tagline {
      color: #a78bfa;
      font-style: italic;
      margin-bottom: 1.5rem;
      padding-left: 1rem;
      border-left: 3px solid var(--accent);
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .skill-tag {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.3);
      border-radius: 8px;
      padding: 0.5rem 1rem;
      color: var(--accent);
      font-size: 0.9rem;
      text-align: center;
      transition: all 0.3s ease;
    }

    .skill-tag:hover {
      background: rgba(16, 185, 129, 0.2);
      box-shadow: var(--glow-green);
      transform: translateY(-2px);
    }

    .links {
      list-style: none;
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .links li a {
      color: var(--secondary);
      text-decoration: none;
      border: 1px solid rgba(6, 182, 212, 0.3);
      padding: 0.6rem 1.2rem;
      border-radius: 8px;
      transition: all 0.3s ease;
      font-weight: 500;
    }

    .links li a:hover {
      background: rgba(6, 182, 212, 0.1);
      border-color: var(--secondary);
      box-shadow: 0 0 12px rgba(6, 182, 212, 0.4);
    }

    /* Section Headers */
    .section-header {
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      font-weight: 700;
      background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 2rem;
      text-align: center;
    }

    /* Software Projects */
    .software-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .software-card {
      background: rgba(15, 23, 42, 0.8);
      backdrop-filter: blur(20px);
      border-radius: 16px;
      border: 1px solid rgba(6, 182, 212, 0.2);
      padding: 2rem;
      transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
      position: relative;
    }

    .software-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, var(--secondary), var(--accent));
      border-radius: 16px 16px 0 0;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .software-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 10px 40px rgba(6, 182, 212, 0.2);
      border-color: rgba(6, 182, 212, 0.5);
    }

    .software-card:hover::before {
      opacity: 1;
    }

    .software-card h3 {
      color: var(--secondary);
      font-size: 1.4rem;
      margin-bottom: 0.75rem;
    }

    .software-card p {
      color: #cbd5e1;
      margin-bottom: 1rem;
      line-height: 1.7;
    }

    .tech-stack {
      background: rgba(6, 182, 212, 0.1);
      border-left: 3px solid var(--secondary);
      padding: 1rem;
      border-radius: 8px;
      color: var(--secondary);
      font-size: 0.95rem;
      font-weight: 500;
    }

    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(40px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-20px);
      }
    }

    @keyframes slideInLeft {
      from {
        opacity: 0;
        transform: translateX(-30px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .card {
      animation: slideInLeft 0.8s ease-out;
    }

    .card:nth-child(2) {
      animation-delay: 0.2s;
    }

    .card:nth-child(3) {
      animation-delay: 0.4s;
    }

    /* Footer */
    footer {
      position: relative;
      z-index: 10;
      text-align: center;
      padding: 3rem 2rem;
      border-top: 1px solid rgba(124, 58, 237, 0.2);
      color: #94a3b8;
    }

    footer p {
      margin-bottom: 0.5rem;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      .hero {
        height: auto;
        min-height: 80vh;
        padding: 3rem 1.5rem;
      }

      .hero h1 {
        font-size: 2rem;
      }

      .profile-card {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .profile-img {
        margin: 0 auto;
      }

      .profile-tagline {
        border-left: none;
        border-top: 3px solid var(--accent);
        padding-left: 0;
        padding-top: 1rem;
      }

      .skills-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .content-grid {
        grid-template-columns: 1fr;
      }

      .links {
        justify-content: center;
      }

      .container {
        padding: 2rem 1rem;
      }
    }

    /* Loading State */
    .loading {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--primary);
      animation: pulse 1.5s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: 0.3;
      }
    }
  </style>
</head>
<body>
  <canvas id="canvas-bg" class="canvas-bg"></canvas>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>Digital Storytelling<br>for Dementia Care</h1>
      <p class="hero-subtitle">Bridging research, lived experience, and creative arts through technology</p>
      <% if (workshopImage) { %>
        <img src="<%= workshopImage %>" alt="World Class Scholars Digital Storytelling Workshop" class="hero-image">
      <% } %>
    </div>
  </section>

  <!-- Main Content -->
  <div class="container">
    <!-- Profile Card -->
    <div class="card profile-card">
      <img src="<%= profile.image %>" alt="<%= profile.name %>" class="profile-img">
      <div class="profile-info">
        <h2><%= profile.name %></h2>
        <div class="profile-title"><%= profile.title %></div>
        <p class="profile-bio"><%= profile.bio %></p>
        <p class="profile-tagline">💡 <%= profile.tagline %></p>

        <div class="skills-grid">
          <% profile.skills.forEach(skill => { %>
            <div class="skill-tag"><%= skill %></div>
          <% }); %>
        </div>

        <ul class="links">
          <% profile.links.forEach(link => { %>
            <li>
              <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer">
                <%= link.label %>
              </a>
            </li>
          <% }); %>
        </ul>
      </div>
    </div>

    <!-- Software Section -->
    <div style="margin-top: 4rem;">
      <h2 class="section-header">Software & Digital Solutions</h2>
      <div class="software-grid">
        <% software.forEach(project => { %>
          <div class="software-card">
            <h3><%= project.title %></h3>
            <p><%= project.description %></p>
            <div class="tech-stack">🛠️ <%= project.tech %></div>
          </div>
        <% }); %>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer>
    <p>🌍 World Class Scholars © 2026</p>
    <p>Global consultancy for social justice, dementia care, and digital healing arts</p>
    <p style="font-size: 0.9rem; color: #64748b;">Built with ❤️ using Node.js, Express, and Canvas animations</p>
  </footer>

  <!-- Canvas Particle Animation -->
  <script>
    const canvas = document.getElementById('canvas-bg');
    const ctx = canvas.getContext('2d');

    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const particles = [];
    const particleCount = 120;

    class Particle {
      constructor() {
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * canvas.height;
        this.vx = (Math.random() - 0.5) * 0.3;
        this.vy = (Math.random() - 0.5) * 0.3;
        this.radius = Math.random() * 2.5 + 0.5;
        this.color = ['rgba(124, 58, 237,', 'rgba(6, 182, 212,', 'rgba(16, 185, 129,'][Math.floor(Math.random() * 3)];
        this.opacity = Math.random() * 0.5 + 0.3;
      }

      update() {
        this.x += this.vx;
        this.y += this.vy;

        if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
        if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
      }

      draw() {
        ctx.fillStyle = this.color + this.opacity + ')';
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // Initialize particles
    for (let i = 0; i < particleCount; i++) {
      particles.push(new Particle());
    }

    // Mouse tracking for interactive particles
    let mouseX = canvas.width / 2;
    let mouseY = canvas.height / 2;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      particles.forEach((particle, index) => {
        particle.update();
        particle.draw();

        // Draw connections between nearby particles
        for (let i = index + 1; i < particles.length; i++) {
          const other = particles[i];
          const dx = particle.x - other.x;
          const dy = particle.y - other.y;
          const distance = Math.sqrt(dx * dx + dy * dy);

          if (distance < 100) {
            ctx.strokeStyle = `rgba(124, 58, 237, ${0.2 * (1 - distance / 100)})`;
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            ctx.moveTo(particle.x, particle.y);
            ctx.lineTo(other.x, other.y);
            ctx.stroke();
          }
        }
      });

      requestAnimationFrame(animate);
    }

    animate();

    // Handle window resize
    window.addEventListener('resize', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    });

    // Smooth scroll animations
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -100px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && entry.target.classList.contains('card')) {
          entry.target.style.animation = 'slideInLeft 0.8s ease-out forwards';
        }
      });
    }, observerOptions);

    document.querySelectorAll('.card').forEach(card => observer.observe(card));

    // Interactive card effects
    document.querySelectorAll('.card, .software-card').forEach(card => {
      card.addEventListener('mouseenter', function() {
        this.style.transition = 'all 0.3s cubic-bezier(0.23, 1, 0.320, 1)';
      });
    });
  </script>
</body>
</html>
