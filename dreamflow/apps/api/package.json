{
  "name": "@dreamflow/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "cd ../.. && nest start api --watch",
    "build": "cd ../.. && nest build api",
    "lint": "echo 'add eslint config'",
    "test": "jest --config ../../jest.config.ts --runInBand --testPathPattern=apps/api/",
